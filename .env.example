# Firebase Environment Variables (Vite Frontend)
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_DATABASE_ID="your-database-id-or-default"

# Sincom / Moblink ERP API Variables (Backend Node & Client)
SINCOM_API_URL="https://api_sincom.caioflix.com.br"
SINCOM_API_TOKEN="your-moblink-jwt-token"
SINCOM_API_USER="your-api-user"
SINCOM_API_PASSWORD="your-api-password"
MOBLINK_EMPRESA_ID="001"
MOBLINK_FILIAL_ID="001"
MOBLINK_WEBHOOK_SECRET="your-moblink-webhook-secret"

VITE_SINCOM_API_URL="https://api_sincom.caioflix.com.br"
VITE_SINCOM_API_USER="your-api-user"
VITE_SINCOM_API_PASSWORD="your-api-password"

# Gemini AI Key & Application Settings
GEMINI_API_KEY="your-gemini-api-key"
APP_URL="http://localhost:3000"

# Cloudinary Configuration (Optional)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
