{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Footwear and accessories store product catalog item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "sizes": { "type": "array" },
        "crediarioProprio": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "stockControl": { "type": "boolean" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "category", "images", "sizes"]
    },
    "Order": {
      "title": "Order",
      "description": "Store order which is finalized on WhatsApp",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "whatsappUrl": { "type": "string" },
        "sellerEmail": { "type": "string" }
      },
      "required": ["customerEmail", "customerName", "items", "total", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account detail containing roles like admin, seller or customer",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Dynamic product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Product collection for catalog"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Dynamic catalog categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Client orders collection"
    },
    "users/{uid}": {
      "schema": "UserProfile",
      "description": "Registered store user profiles"
    }
  }
}
